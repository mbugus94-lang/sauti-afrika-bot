# Minimal local dev (no external APIs)
NODE_ENV=development
PORT=3000

# Auth (optional for local)
DISABLE_AUTH=true
DEV_USER_ID=1
DEV_USER_OPENID=dev-user
DEV_USER_NAME=Developer
DEV_USER_ROLE=admin

# Database
DISABLE_DB=true
# DATABASE_URL=mysql://user:pass@localhost:3306/africa_lang

# LLM
LLM_PROVIDER=mock
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_API_KEY=
LLM_MODEL=llama3.1:8b
LLM_MAX_TOKENS=2048
LLM_THINKING_BUDGET=0
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_MS=60000

# Language
DEFAULT_LANGUAGE=en
DISABLE_LANGUAGE_DETECTION=true
DISABLE_TRANSLATION=true
DEFAULT_SYSTEM_PROMPT=

# Feature flags
DISABLE_TOOLS=false
DISABLE_VOICE=true
DISABLE_IMAGE=true

# Channel integrations (planned)
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=

# Forge / Manus services (optional)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
OAUTH_SERVER_URL=
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
JWT_SECRET=
OWNER_OPEN_ID=
